{
  "$id": "https://creel.dev/schema/graph/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "directed": {
      "type": "boolean"
    },
    "edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "attributes": {
            "type": "object"
          },
          "id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "source",
          "target",
          "type",
          "attributes"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "nodes": {
      "additionalProperties": {
